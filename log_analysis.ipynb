    "import pm4py\n",
    "import pandas as pd\n",
    "\n",
    "log = pd.read_csv(\"log_data.csv\")\n",
    "\n",
    "log = pm4py.format_dataframe(\n",
    "    log,\n",
    "    case_id='Case_ID',\n",
    "    activity_key='Activity',\n",
    "    timestamp_key='Timestamp'\n",
    ")\n",
    "\n",
    "net, im, fm = pm4py.discover_petri_net_inductive(log)\n",
    "\n",
    "pm4py.view_petri_net(net, im, fm)"
